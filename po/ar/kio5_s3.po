msgstr "تشكيلة من ~/.aws/credentials"

#: kcm/ui/main.qml:187
#, kde-format
msgctxt "@title:group"
msgid "Advanced"
msgstr "متقدّم"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "استخدم عناوين URL بنمط المسار S3"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "احذف التشكيلة"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "هل أنت متأكد من رغبتك في حذف التشكيلة \"%1\"؟"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"عنوان اس3 غير صالح، اسم الحاوية مفقود من المضيف. <nl/> يجب كتابة عنوان اس3 "
"صالح بالشكل:  <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "لم يعثر على حاوية اس3، رجاء تأكد من ضبط AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr "لا يمكن النسخ بين ملفات تشكيلات S3 مختلفة. انسخ الملف محليًا أولاً."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "لا يمكن نسخ <link>%1</link> إلى <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "لا يمكن إعادة التسمية بين ملفات تشكيلات S3 المختلفة."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"تعذر حذف بعض الملفات المصدرية بعد إعادة تسميتها. قد لا يزال المجلد المعاد "
"تسميته يحتوي على ملفات متبقية."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr "تعذر استرداد قائمة الملفات الكاملة. قد لا تظهر بعض الملفات."

#~ msgid "Advanced"
#~ msgstr "متقدّم"
