msgstr "مثال، https://s3.example.com"

#: kcm/ui/main.qml:164
#, kde-format
msgid "Region:"
msgstr "المنطقة:"

#: kcm/ui/main.qml:165
#, kde-format
msgid "e.g., us-east-1, auto"
msgstr "مثال, us-east-1, auto"

#: kcm/ui/main.qml:171
#, kde-format
msgctxt "@title:group"
msgid "Authentication"
msgstr "الاستيثاق"

#: kcm/ui/main.qml:180
#, kde-format
