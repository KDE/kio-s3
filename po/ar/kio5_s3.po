msgstr "على سبيل المثال، تخزين S3 الخاص بي"

#: kcm/ui/main.qml:155
#, kde-format
msgid "Endpoint URL:"
msgstr "عنوان نقطة النهاية:"

#: kcm/ui/main.qml:156
#, kde-format
