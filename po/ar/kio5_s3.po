msgstr "لم يضبط أي تشكيلة S3"

#: kcm/ui/main.qml:26
#, kde-format
msgid "Add a profile to connect to an S3-compatible storage backend"
msgstr "أضف تشكيلة للاتصال بخلفية تخزين متوافقة مع S3"

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "أضف تشكيلة…"

#: kcm/ui/main.qml:72
#, kde-format
msgid "Default AWS endpoint"
msgstr "نقطة نهاية AWS المبدئية"

#: kcm/ui/main.qml:89
#, kde-format
msgid "Edit"
msgstr "حرّر"

#: kcm/ui/main.qml:94 kcm/ui/main.qml:242
#, kde-format
