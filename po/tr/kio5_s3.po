msgstr "Yol olarak biçimli S3 URL’leri kullan"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Profili Sil"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "“%1” profilini silmek istediğinizden emin misiniz?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Geçersiz S3 URI’si; ana makineden kova adı eksik.<nl/>Geçerli bir S3 URI’si "
"şöyle yazılmalıdır: <link>s3://bucket/key</link>."

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "S3 kovaları bulunamadı; lütfen AWS yapılandırmanızı denetleyin."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Farklı S3 profilleri arasında kopyalama yapılamıyor. Lütfen dosyayı önce "
"yerel olarak kopyalayın."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "<link>%1</link>, <link>%2</link> konumuna kopyalanamadı."

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Farklı S3 profilleri arasında yeniden adlandırma yapılamıyor."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Yeniden adlandırma sonrası bazı kaynak dosyaları silinemedi. Yeniden "
"adlandırılan klasörde hâlâ kalan dosyalar olabilir."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr "Tam dosya listesi alınamadı. Bazı dosyalar gösterilmiyor olabilir."

#~ msgid "Advanced"
#~ msgstr "Gelişmiş"
