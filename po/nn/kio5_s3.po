#: s3backend.cpp:41
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Ugyldig S3-adresse. Bøttenamn manglar hos verten.<nl/>Ei gyldig S3-adresse "
"må vera på denne forma: <link>s3://bøtte/nøkkel</link>"

#: s3backend.cpp:140 s3backend.cpp:149
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "Fann ikkje S3-bøtter. Kontroller AWS-oppsettet."

#: s3backend.cpp:622
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr "Kan ikkje kopiera mellom ulike S3-profilar. Kopier fila lokalt først."

#: s3backend.cpp:673
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Klarte ikkje kopiera <link>%1</link> til <link>%2</link>"

#: s3backend.cpp:748
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Kan ikkje endra namn mellom ulike S3-profilar."

#: s3backend.cpp:877
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Nokre kjeldefiler kunne ikkje slettast etter nameendringa. Mappa med endra "
"namn kan framleis innehalda nokre filer."

#: s3backend.cpp:939 s3backend.cpp:1000
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Klarte ikkje henta fullstendig filliste. Det kan vera ikkje alle filer vert "
"viste."
