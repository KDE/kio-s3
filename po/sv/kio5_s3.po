msgstr "Är du säker på att du vill ta bort profilen \"%1\"?"

#: s3backend.cpp:41
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Ogiltig S3 webbadress, spannamn saknas från värddatorn.<nl/>En giltig S3 "
"webbadress måste skrivas på formen: <link>s3://spann/nyckel</link>"

#: s3backend.cpp:140 s3backend.cpp:149
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "Kunde inte hitta S3-spann, kontrollera AWS-inställningen."

#: s3backend.cpp:622
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr "Kan inte kopiera mellan olika S3-profiler. Kopiera filen lokalt först."

#: s3backend.cpp:673
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Kunde inte kopiera <link>%1</link> till <link>%2</link>"

#: s3backend.cpp:748
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Kan inte byta namn mellan olika S3-profiler."

#: s3backend.cpp:877
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Vissa källfiler kunde inte tas bort efter namnbytet. Katalogen med det nya "
"namnet kan fortfarande innehålla kvarvarande filer."

#: s3backend.cpp:939 s3backend.cpp:1000
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Kunde inte hämta den fullständiga fillistan. Vissa filer kanske inte visas."
