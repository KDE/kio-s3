#: kcm/ui/main.qml:25
#, kde-format
msgid "No S3 profiles configured"
msgstr "Не налаштовано жодного профілю S3"

#: kcm/ui/main.qml:26
#, kde-format
msgid "Add a profile to connect to an S3-compatible storage backend"
msgstr ""
"Додайте профіль для встановлення з'єднання із сумісним із S3 модулем сховища "
"даних"

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "Додати профіль…"

#: kcm/ui/main.qml:72
#, kde-format
msgid "Default AWS endpoint"
msgstr "Типова кінцева точка AWS"

#: kcm/ui/main.qml:89
#, kde-format
msgid "Edit"
msgstr "Змінити"

#: kcm/ui/main.qml:94 kcm/ui/main.qml:242
#, kde-format
msgid "Delete"
msgstr "Вилучити"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Add S3 Profile"
msgstr "Додати профіль S3"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Edit S3 Profile"
msgstr "Редагувати профіль S3"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Add"
msgstr "Додати"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Save"
msgstr "Зберегти"

#: kcm/ui/main.qml:147
#, kde-format
msgid "Name:"
msgstr "Назва:"

#: kcm/ui/main.qml:148
#, kde-format
msgid "e.g., My S3 Storage"
msgstr "Приклад: Моє сховище S3"

#: kcm/ui/main.qml:155
#, kde-format
msgid "Endpoint URL:"
msgstr "Адреса кінцевої точки:"

#: kcm/ui/main.qml:156
#, kde-format
msgid "e.g., https://s3.example.com"
msgstr "Приклад: https://s3.example.com"

#: kcm/ui/main.qml:164
#, kde-format
msgid "Region:"
msgstr "Область:"

#: kcm/ui/main.qml:165
#, kde-format
msgid "e.g., us-east-1, auto"
msgstr "Приклад: us-east-1, auto"

#: kcm/ui/main.qml:171
#, kde-format
msgctxt "@title:group"
msgid "Authentication"
msgstr "Розпізнавання"

#: kcm/ui/main.qml:180
#, kde-format
msgid "AWS Profile:"
msgstr "Профіль AWS:"

#: kcm/ui/main.qml:181
#, kde-format
msgid "Profile from ~/.aws/credentials"
msgstr "Профіль з ~/.aws/credentials"

#: kcm/ui/main.qml:187
#, kde-format
msgctxt "@title:group"
msgid "Advanced"
msgstr "Додатково"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "Використовувати адреси S3 у стилі шляхів"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Вилучити профіль"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "Ви справді хочете вилучити профіль «%1»?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Некоректна адреса S3 — у записі вузла не вистачає назви кошика.<nl/>Коректна "
"адреса S3 повинна мати таку форму: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr ""
"Не вдалося знайти кошики S3. Будь ласка, перевірте, чи правильно вказано "
"налаштування AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Копіювання між різними профілями S3 неможливе. Спочатку скопіюйте файл на "
"ваш комп'ютер."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Не вдалося скопіювати <link>%1</link> до <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Перейменування між різними профілями S3 неможливе."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Деякі початкові файли не вдалося вилучити після перейменування. У "
"перейменованій теці можуть усе ще міститися залишки початкових файлів."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Не вдалося отримати повний список файлів. Деякі файли може бути не показано."

#~ msgid "Advanced"
#~ msgstr "Додатково"
