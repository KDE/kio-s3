#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "პროფილის წაშლა"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "მართლა გნებავთ, წაშალოთ პროფილი \"%1\"?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"S3-ის არასწორი URI. ჰოსტს bucket-ის სახელი აკლია.<nl/>S3-ის ჩანაწერის სწორი "
"ფორმაა: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr ""
"S3-ის ბაკეტების პოვნა შეუძლებელია. შეამოწმეთ თქვენი AWS-ის კონფიგურაცია."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"სხვადსხვა S3-ის პროფილებს შორის კოპირება შეუძლებელია. ჯერ ფაილი ლოკალურად "
"დააკოპირეთ."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "<link>%1</link>-დან <link>%2</link>მდე კოპირების შეცდომა"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "სხვადსხვა S3-ის პროფილებს შორის სახელის გადარქმევა შეუძლებელია."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"სახელის გადარქმევის შემდეგ ზოგიერთი წყარო ფაილის წაშლა შეუძლებელია. "
"სახელგადარქმეული საქაღალდე, შეიძლება, ჯერ კიდევ შეიცავდეს ნარჩენ ფაილებს."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"ფაილების სრული სიის მიღება შეუძლებელია. შეიძლება, ზოგიერთი ფაილი ნაჩვენები "
"არ იყოს."

#~ msgid "Advanced"
#~ msgstr "დამატებით"
