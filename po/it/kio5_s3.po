msgstr "ad es., us-east-1, auto"

#: kcm/ui/main.qml:171
#, kde-format
msgctxt "@title:group"
msgid "Authentication"
msgstr "Autenticazione"

#: kcm/ui/main.qml:180
#, kde-format
msgid "AWS Profile:"
msgstr "Profilo AWS:"

#: kcm/ui/main.qml:181
#, kde-format
msgid "Profile from ~/.aws/credentials"
msgstr "Profilo da ~/.aws/credentials"

#: kcm/ui/main.qml:187
#, kde-format
msgctxt "@title:group"
msgid "Advanced"
msgstr "Avanzate"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "Usa gli URL di percorso S3"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Elimina profilo"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "Sei sicuro di voler eliminare il profilo «%1»?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"URI S3 non valido, nome del bucket mancante dall'host.<nl/>Un URI S3 valido "
"deve essere scritto nella forma: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "Impossibile trovare bucket S3, controlla la tua configurazione di AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Impossibile copiare tra diversi profili S3. Copia prima il file localmente."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Impossibile copiare <link>%1</link> in <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Impossibile rinominare tra diversi profili S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Alcuni file sorgente non sono stati eliminati dopo la rinomina. La cartella "
"rinominata potrebbe contenere ancora dei file."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Impossibile recuperare l'elenco completo dei file. Alcuni file potrebbero "
"non essere visualizzati."
