#: kcm/ui/main.qml:25
#, kde-format
msgid "No S3 profiles configured"
msgstr "Nessun profilo S3 configurato"

#: kcm/ui/main.qml:26
#, kde-format
msgid "Add a profile to connect to an S3-compatible storage backend"
msgstr ""
"Aggiungi un profilo per connetterti a un motore di archiviazione compatibile "
"con S3"

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "Aggiungi profilo…"

#: kcm/ui/main.qml:72
#, kde-format
