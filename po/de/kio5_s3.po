#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "S3-Adressen im Pfad-Stil verwenden"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Profil löschen"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "Möchten Sie das Profil „%1“ wirklich löschen?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Ungültige S3-URI, der Name des Buckets fehlt am Host.<nl/>Eine gültige S3-"
"URI hat folgende Syntax: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr ""
"S3-Buckets konnten nicht gefunden werden, bitte überprüfen Sie Ihre AWS-"
"Konfiguration."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Kopieren zwischen unterschiedlichen S3-Profilen nicht möglich. Kopieren Sie "
"die Datei erst lokal."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "<link>%1</link> kann nicht nach <link>%2</link> kopiert werden"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Umbenennen zwischen unterschiedlichen S3-Profilen nicht möglich."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Einige Quelldateien können nach dem Umbenennen nicht gelöscht werden. Der "
"umbenannte Ordner könnte immer noch übrig gebliebene Dateien enthalten."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Die vollständige Dateiliste kann nicht abgerufen werden. Einige Dateien "
"werden möglicherweise nicht angezeigt."
