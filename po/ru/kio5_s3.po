#: kcm/ui/main.qml:25
#, kde-format
msgid "No S3 profiles configured"
msgstr "Профили S3 не настроены"

#: kcm/ui/main.qml:26
#, kde-format
msgid "Add a profile to connect to an S3-compatible storage backend"
msgstr "Добавление профиля для подключения к хранилищу, совместимому с S3"

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "Добавить профиль…"

#: kcm/ui/main.qml:72
#, kde-format
msgid "Default AWS endpoint"
msgstr "Стандартная конечная точка AWS"

#: kcm/ui/main.qml:89
#, kde-format
msgid "Edit"
msgstr "Изменить"

#: kcm/ui/main.qml:94 kcm/ui/main.qml:242
#, kde-format
msgid "Delete"
msgstr "Удалить"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Add S3 Profile"
msgstr "Добавление профиля S3"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Edit S3 Profile"
msgstr "Изменение профиля S3"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Add"
msgstr "Добавить"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Save"
msgstr "Сохранить"

#: kcm/ui/main.qml:147
#, kde-format
msgid "Name:"
msgstr "Название:"

#: kcm/ui/main.qml:148
#, kde-format
msgid "e.g., My S3 Storage"
msgstr "Например, «Мое хранилище S3»"

#: kcm/ui/main.qml:155
#, kde-format
msgid "Endpoint URL:"
msgstr "URL конечной точки:"

#: kcm/ui/main.qml:156
#, kde-format
msgid "e.g., https://s3.example.com"
msgstr "например, https://s3.example.com"

#: kcm/ui/main.qml:164
#, kde-format
msgid "Region:"
msgstr "Регион:"

#: kcm/ui/main.qml:165
#, kde-format
msgid "e.g., us-east-1, auto"
msgstr "например, us-east-1, auto"

#: kcm/ui/main.qml:171
#, kde-format
msgctxt "@title:group"
msgid "Authentication"
msgstr "Аутентификация"

#: kcm/ui/main.qml:180
#, kde-format
msgid "AWS Profile:"
msgstr "Профиль AWS:"

#: kcm/ui/main.qml:181
#, kde-format
msgid "Profile from ~/.aws/credentials"
msgstr "Профиль из ~/.aws/credentials"

#: kcm/ui/main.qml:187
#, kde-format
msgctxt "@title:group"
msgid "Advanced"
msgstr "Дополнительно"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "Использовать URL S3 в стиле пути"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Удалить профиль"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "Вы уверены, что хотите удалить профиль «%1»?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Некорректный URI-адрес S3; в записи узла не хватает имени бакета.<nl/"
">Корректный URI-адрес S3 должен быть записан в следующем формате: <link>s3://"
"bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "Не удалось найти бакеты S3. Проверьте конфигурацию AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Невозможно копировать между разными профилями S3. Сначала скопируйте файл "
"локально."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Не удалось скопировать <link>%1</link> в <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Невозможно переименовать между разными профилями S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Некоторые исходные файлы не удалось удалить после переименования. "
"Переименованная папка может содержать оставшиеся файлы."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Не удалось получить полный список файлов. Некоторые файлы могут "
"отсутствовать."

#~ msgid "Advanced"
#~ msgstr "Дополнительно"
