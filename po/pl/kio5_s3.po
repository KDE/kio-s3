msgstr "Czy na pewno chcesz usunąć profil \"%1\"?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Nieprawidłowy adres URI S3, brakuje nazwy bucket w nazwie gospodarza.<nl/"
">Prawidłowy adres URI S3 musi mieć następujący zapis: <link>s3://bucket/key</"
"link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "Nie można znaleźć bucketów S3, sprawdź swoje ustawienia AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Nie można kopiować pomiędzy różnymi profilami S3. Najpierw skopiuj plik "
"lokalnie."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Nie można skopiować <link>%1</link> do <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Nie można zmieniać nazwy pomiędzy różnymi profilami S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Niektórych z plików źródłowych nie da się usunąć po zmianie nazwy. Katalog o "
"zmienionej nazwie nadal może zawierać takie pozostałości."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Nie można uzyskać spisu wszystkich plików. Niektóre z plików mogą być "
"niewidoczne."
