#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"URI S3 no válido: falta el nombre del depósito del servidor.<nl/>Un URI S3 "
"válido debe tener la forma: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "No se han encontrado depósitos S3. Compruebe la configuración de AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"No se puede copiar entre distintos perfiles S3. Copie primero el archivo de "
"forma local."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "No se ha podido copiar <link>%1</link> en <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "No se puede cambiar el nombre entre distintos perfiles S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Algunos archivos de origen no se pueden borrar tras cambiar su nombre. La "
"carpeta cuyo nombre se ha cambiado puede seguir conteniendo archivos "
"sobrantes."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"No se ha podido obtener el listado completo de archivos. Es posible que no "
"se muestren algunos archivos."

