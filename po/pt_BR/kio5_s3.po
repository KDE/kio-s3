msgstr "Editar"

#: kcm/ui/main.qml:94 kcm/ui/main.qml:242
#, kde-format
msgid "Delete"
msgstr "Excluir"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Add S3 Profile"
msgstr "Adicionar perfil S3"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Edit S3 Profile"
msgstr "Editar perfil S3"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Add"
msgstr "Adicionar"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Save"
msgstr "Salvar"

#: kcm/ui/main.qml:147
#, kde-format
msgid "Name:"
msgstr "Nome:"

#: kcm/ui/main.qml:148
#, kde-format
msgid "e.g., My S3 Storage"
msgstr "por exemplo, Meu Armazenamento S3"

#: kcm/ui/main.qml:155
#, kde-format
msgid "Endpoint URL:"
msgstr "URL do ponto de saída:"

#: kcm/ui/main.qml:156
#, kde-format
msgid "e.g., https://s3.example.com"
msgstr "por exemplo, https://s3.exemplo.com"

#: kcm/ui/main.qml:164
#, kde-format
msgid "Region:"
msgstr "Região:"

#: kcm/ui/main.qml:165
#, kde-format
msgid "e.g., us-east-1, auto"
msgstr "por exemplo, us-east-1, auto"

#: kcm/ui/main.qml:171
#, kde-format
msgctxt "@title:group"
msgid "Authentication"
msgstr "Autenticação"

#: kcm/ui/main.qml:180
#, kde-format
msgid "AWS Profile:"
msgstr "Perfil AWS:"

#: kcm/ui/main.qml:181
#, kde-format
msgid "Profile from ~/.aws/credentials"
msgstr "Perfil a partir de ~/.aws/credentials"

#: kcm/ui/main.qml:187
#, kde-format
msgctxt "@title:group"
msgid "Advanced"
msgstr "Avançado"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "Usar URLs S3 no estilo de caminho"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Excluir perfil"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "Tem certeza de que deseja excluir o perfil \"%1\"?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"URI S3 inválida, o nome do bucket está faltando no host.<nl/>Uma URI S3 "
"válida deve ser escrita na forma: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr ""
"Não foi possível encontrar buckets S3, verifique sua configuração do AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Não é possível copiar entre diferentes perfis do S3. Primeiro, copie o "
"arquivo localmente."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Não foi possível copiar <link>%1</link> para <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Não é possível renomear entre diferentes perfis do S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Alguns arquivos de origem não puderam ser excluídos após a renomeação. A "
"pasta renomeada ainda pode conter arquivos residuais."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Não foi possível recuperar a lista completa de arquivos. Alguns arquivos "
"podem não ser exibidos."

#~ msgid "Advanced"
#~ msgstr "Avançado"
