#: kcm/ui/main.qml:25
#, kde-format
msgid "No S3 profiles configured"
msgstr "Nenhum perfil S3 configurado"

#: kcm/ui/main.qml:26
#, kde-format
msgid "Add a profile to connect to an S3-compatible storage backend"
msgstr ""
"Adicionar um perfil para se conectar a um backend de armazenamento "
"compatível com S3"

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "Adicionar perfil…"

#: kcm/ui/main.qml:72
#, kde-format
msgid "Default AWS endpoint"
msgstr "Ponto de saída AWS padrão"

#: kcm/ui/main.qml:89
#, kde-format
