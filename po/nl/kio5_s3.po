msgstr "Wilt u het profiel \"%1\" werkelijk wissen?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Ongeldige S3 URI, bucketnaam ontbreekt in de host.<nl/>Een geldige S3 URI "
"moet geschreven zijn in de vorm: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "S3-buckets zijn niet gevonden, controleer uw AWS-configuratie."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Kan niet kopiëren tussen verschillende S3-profielen. Kopieer het bestand "
"eerst lokaal."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Kon <link>%1</link> niet kopiëren naar <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Kan tussen verschillende S3-profielen niet hernoemen."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Enige bronbestanden konden niet verwijderd worden na hernoemen. De hernoemde "
"map kan nog steeds overgebleven bestanden bevatten."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Kon de volledige lijstmet bestanden niet ophalen. Sommige bestanden kunnen "
"niet getoond worden."
