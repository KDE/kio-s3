#: kcm/ui/main.qml:25
#, kde-format
msgid "No S3 profiles configured"
msgstr "Ez da S3 profilik konfiguratu"

#: kcm/ui/main.qml:26
#, kde-format
msgid "Add a profile to connect to an S3-compatible storage backend"
msgstr ""
"Gehitu S3rekin bateragarria den gordetegi bizkarraldeko batera konektatzeko "
"profil bat."

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "Gehitu profila…"

#: kcm/ui/main.qml:72
#, kde-format
msgid "Default AWS endpoint"
msgstr "AWS bukaera-puntu lehenetsia"

#: kcm/ui/main.qml:89
#, kde-format
msgid "Edit"
msgstr "Editatu"

#: kcm/ui/main.qml:94 kcm/ui/main.qml:242
#, kde-format
msgid "Delete"
msgstr "Ezabatu"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Add S3 Profile"
msgstr "Gehitu S3 profila"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Edit S3 Profile"
msgstr "Editatu S3 profila"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Add"
msgstr "Gehitu"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Save"
msgstr "Gorde"

#: kcm/ui/main.qml:147
#, kde-format
msgid "Name:"
msgstr "Izena:"

#: kcm/ui/main.qml:148
#, kde-format
msgid "e.g., My S3 Storage"
msgstr "adib. Nire S3 gordetegia"

#: kcm/ui/main.qml:155
#, kde-format
msgid "Endpoint URL:"
msgstr "Bukaera-puntuko URLa:"

#: kcm/ui/main.qml:156
#, kde-format
msgid "e.g., https://s3.example.com"
msgstr "adib., https://s3.example.com"

#: kcm/ui/main.qml:164
#, kde-format
msgid "Region:"
msgstr "Eskualdea:"

#: kcm/ui/main.qml:165
#, kde-format
msgid "e.g., us-east-1, auto"
msgstr "adib., us-east-1, auto"

#: kcm/ui/main.qml:171
#, kde-format
msgctxt "@title:group"
msgid "Authentication"
msgstr "Autentifikazioa"

#: kcm/ui/main.qml:180
#, kde-format
msgid "AWS Profile:"
msgstr "AWS profila:"

#: kcm/ui/main.qml:181
#, kde-format
msgid "Profile from ~/.aws/credentials"
msgstr "“~/.aws/credentials”ko profila"

#: kcm/ui/main.qml:187
#, kde-format
msgctxt "@title:group"
msgid "Advanced"
msgstr "Aurreratua"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "Erabili bide-izen estiloko S3 URLak"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Ezabatu profila"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "Ziur zaude \"%1\" profila ezabatu nahi duzula?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"S3 URI baliogabea, ostalarian «bucket» izena falta da.<nl/>S3 URI baliodun "
"bat idatzi behar da, formatu honekin: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr ""
"Ezin izan da S3 «bucket»ik aurkitu, mesedez, egiaztatu zure AWS "
"konfigurazioa."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Ezin da S3 profil ezberdinen artean kopiatu. Aurrena fitxategia lokalki "
"kopiatu."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Ezin izan du <link>%1</link> <link>%2</link>(e)ra kopiatu"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Ezin da S3 profil ezberdinen artean berrizendatu."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Berrizendatu ondoren jatorrizko fitxategi batzuk ezin izan dira ezabatu. "
"Baliteke berrizendatutako karpetan oraindik hondar-fitxategiak egotea."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Ezin izan da fitxategien zerrenda osoa eskuratu. Baliteke fitxategi batzuk "
"ez agertzea."

#~ msgid "Advanced"
#~ msgstr "Aurreratua"
