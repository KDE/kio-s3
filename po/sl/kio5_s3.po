msgstr "Ali ste prepričani, da želite izbrisati profil \"%1\"?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Neveljaven naslov S3, pri gostitelju manjka ime vedra.<nl/>Veljaven naslov "
"S3 mora biti napisano v obliki: <link>s3://vedro/ključ</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "Ni bilo mogoč najti vedra S3, preverite vašo konfiguracijo AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Kopiranje med različnimi profili S3 ni mogoče. Najprej kopirajte datoteko "
"lokalno."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Ni bilo mogoče kopirati <link>%1</link> v <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Preimenovanje med različnimi profili S3 ni mogoče."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Nekaterih izvornih datotek po preimenovanju ni bilo mogoče izbrisati. "
"Preimenovana mapa lahko še vedno vsebuje preostale datoteke."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Celotnega seznama datotek ni bilo mogoče pridobiti. Nekatere datoteke morda "
"niso prikazane."

#~ msgid "Advanced"
#~ msgstr "Napredni"
