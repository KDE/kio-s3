msgstr "Avancé"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "Utiliser les URL S3 de style emplacement"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "Supprimer le profil"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "Voulez-vous vraiment supprimer le profil « %1 » ?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"URI « S3 » non valable, le nom du panier est absent de l'hôte.<nl/>Une URI "
"« S3 » valable doit être écrite sous la forme : <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr ""
"Impossible de trouver les conteneurs « S3 ». Veuillez vérifier votre "
"configuration « AWS »."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Impossible de faire une copie entre différents profils S3. Veuillez d'abord "
"copier le fichier localement."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Impossible de copier <link>%1</link> vers <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Impossible de faire un renommage entre différents profils S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Certains fichiers sources n’ont pas pu être supprimés après renommage. Le "
"dossier renommé peut encore contenir des fichiers restants."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"Impossible de recharger la liste complète des fichiers. Certains fichiers "
"peuvent ne pas être affichés."

#~ msgid "Advanced"
#~ msgstr "Avancé"
