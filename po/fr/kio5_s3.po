msgstr ""
"Ajoutez un profil pour vous connecter à un enregistrement compatible avec S3"

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "Ajouter un profil..."

