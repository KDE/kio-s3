#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "Nemôžem skopírovať <link>%1</link> do <link>%2</link>"

#: s3backend.cpp:748
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "Nie je možné rename between different S3 profiles."

#: s3backend.cpp:877
#, kde-format
msgctxt "@info"
msgid ""
