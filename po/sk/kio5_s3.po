#: s3backend.cpp:41
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"Neplatné URI S3, názov koša chýba z hostiteľa.<nl/>Platné S3 URI musí byť "
"zapísané vo formáte:  <link>s3://bucket/key</link>"

#: s3backend.cpp:140 s3backend.cpp:149
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "Nemôžem nájsť S3 buckety, skontrolujte vaše nastavenie AWS."

#: s3backend.cpp:622
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"Nie je možné copy between different S3 profiles. Copy the file locally first."

