msgstr "Segur que voleu eliminar el perfil «%1»?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"L'URI de S3 no és vàlid, falta el nom del compartiment a l'amfitrió.<nl/"
">S'ha d'escriure un URI de S3 vàlid en la forma: <link>s3://compartiment/"
"clau</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr ""
"No s'ha trobat cap compartiment S3, comproveu la vostra configuració d'AWS."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"No es pot copiar entre diferents perfils S3. Primer copieu el fitxer "
"localment."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "No s'ha pogut copiar <link>%1</link> en <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "No s'ha pogut canviar de nom entre diferents perfils S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"Alguns fitxers d'origen no s'han pogut suprimir després de canviar-ne el "
"nom. La carpeta reanomenada encara pot contindre fitxers sobrants."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr ""
"No s'ha pogut recuperar el llistat complet de fitxers. És possible que "
"alguns fitxers no es mostren."
