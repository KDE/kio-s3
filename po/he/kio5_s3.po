#: kcm/ui/main.qml:25
#, kde-format
msgid "No S3 profiles configured"
msgstr "לא נבחרו פרופילים של S3"

#: kcm/ui/main.qml:26
#, kde-format
msgid "Add a profile to connect to an S3-compatible storage backend"
msgstr "יש להוסיף פרופיל כדי להתחבר למנגנון אחסון תואם S3"

#: kcm/ui/main.qml:30 kcm/ui/main.qml:37
#, kde-format
msgid "Add Profile…"
msgstr "הוספת פרופיל…"

#: kcm/ui/main.qml:72
#, kde-format
msgid "Default AWS endpoint"
msgstr "נקודת הגישה של AWS כברירת מחדל"

#: kcm/ui/main.qml:89
#, kde-format
msgid "Edit"
msgstr "עריכה"

#: kcm/ui/main.qml:94 kcm/ui/main.qml:242
#, kde-format
msgid "Delete"
msgstr "מחיקה"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Add S3 Profile"
msgstr "הוספת פרופיל S3"

#: kcm/ui/main.qml:105
#, kde-format
msgid "Edit S3 Profile"
msgstr "עריכת פרופיל S3"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Add"
msgstr "הוספה"

#: kcm/ui/main.qml:116
#, kde-format
msgid "Save"
msgstr "שמירה"

#: kcm/ui/main.qml:147
#, kde-format
msgid "Name:"
msgstr "שם:"

#: kcm/ui/main.qml:148
#, kde-format
msgid "e.g., My S3 Storage"
msgstr "למשל, האחסון שלי ב־S3"

#: kcm/ui/main.qml:155
#, kde-format
msgid "Endpoint URL:"
msgstr "כתובת נקודת גישה:"

#: kcm/ui/main.qml:156
#, kde-format
msgid "e.g., https://s3.example.com"
msgstr "למשל, https://s3.example.com"

#: kcm/ui/main.qml:164
#, kde-format
msgid "Region:"
msgstr "אזור:"

#: kcm/ui/main.qml:165
#, kde-format
msgid "e.g., us-east-1, auto"
msgstr "למשל, us-east-1,‏ auto"

#: kcm/ui/main.qml:171
#, kde-format
msgctxt "@title:group"
msgid "Authentication"
msgstr "אימות"

#: kcm/ui/main.qml:180
#, kde-format
msgid "AWS Profile:"
msgstr "פרופיל AWS:"

#: kcm/ui/main.qml:181
#, kde-format
msgid "Profile from ~/.aws/credentials"
msgstr "פרופיל מ־‎~/.aws/credentials"

#: kcm/ui/main.qml:187
#, kde-format
msgctxt "@title:group"
msgid "Advanced"
msgstr "מתקדם"

#. i18n("Addressing:")
#: kcm/ui/main.qml:199
#, kde-format
msgid "Use path-style S3 URLs"
msgstr "להשתמש בכתובות S3 בסגנון נתיב"

#: kcm/ui/main.qml:235
#, kde-format
msgid "Delete Profile"
msgstr "מחיקת פרופיל"

#: kcm/ui/main.qml:236
#, kde-format
msgid "Are you sure you want to delete the profile \"%1\"?"
msgstr "למחוק את הפרופיל „%1”?"

#: s3backend.cpp:38
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Invalid S3 URI, bucket name is missing from the host.<nl/>A valid S3 URI "
"must be written in the form: <link>s3://bucket/key</link>"
msgstr ""
"כתובת ה־S3 המלאה שגויה, שם הדלי חסר במארח.<nl/>כתובת S3 מלאה תקפה יש לכתוב "
"בצורה: <link>s3://bucket/key</link>"

#: s3backend.cpp:137 s3backend.cpp:146
#, kde-kuit-format
msgctxt "@info"
msgid "Could not find S3 buckets, please check your AWS configuration."
msgstr "לא ניתן למצוא דליים של S3, נא לבדוק שהגדרות ה־AWS שלך תקינות."

#: s3backend.cpp:518
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot copy between different S3 profiles. Copy the file locally first."
msgstr ""
"לא ניתן להעתיק בין פרופילים שונים של S3. יש להעתיק את הקבצים מקומית תחילה."

#: s3backend.cpp:569
#, kde-kuit-format
msgctxt "@info"
msgid "Could not copy <link>%1</link> to <link>%2</link>"
msgstr "לא ניתן להעתיק את <link>%1</link> אל <link>%2</link>"

#: s3backend.cpp:644
#, kde-kuit-format
msgctxt "@info"
msgid "Cannot rename between different S3 profiles."
msgstr "לא ניתן לשנות שם בין פרופילים שונים של S3."

#: s3backend.cpp:773
#, kde-format
msgctxt "@info"
msgid ""
"Some source files could not be deleted after renaming. The renamed folder "
"may still contain leftover files."
msgstr ""
"את חלק מקובצי המקור לא ניתן למחוק לאחר שינוי שם. התיקייה ששמה השתנה עלולה "
"עדיין להכיל קבצים שנותרו מאחור."

#: s3backend.cpp:835 s3backend.cpp:896
#, kde-format
msgctxt "@info"
msgid ""
"Could not retrieve the complete file listing. Some files may not be shown."
msgstr "לא ניתן למשוך את רשימת הקבצים המלאה. יכול להיות שיש קבצים שלא יופיעו."

#~ msgid "Advanced"
#~ msgstr "מתקדם"
